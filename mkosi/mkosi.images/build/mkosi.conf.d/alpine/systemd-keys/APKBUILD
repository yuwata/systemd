pkgname=systemd-keys
pkgver=1
pkgrel=0
pkgdesc="Public keys for systemd packages and repository index built in mkosi"
url="https://systemd.io/"
arch="all"
license="MIT"
options="!check" # No testsuite

package() {
        install -Dm644 "$srcdir"/*.rsa.pub -t "$pkgdir"/etc/apk/keys/
}
